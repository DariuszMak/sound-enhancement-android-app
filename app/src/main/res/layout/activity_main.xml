<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp">


        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/statusDot"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:text="●"
                android:textSize="24sp" />

            <TextView
                android:id="@+id/statusLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="18sp"
                android:textStyle="bold" />

        </LinearLayout>


        <Button
            android:id="@+id/btnStart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:backgroundTint="#4CAF50"
            android:text="ON"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnStop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="#F44336"
            android:text="OFF"
            android:textColor="#FFFFFF" />


        <LinearLayout
            android:id="@+id/eqPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="vertical">


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="EQ Settings"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnReset"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:backgroundTint="#9E9E9E"
                    android:text="Reset to defaults"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />

            </LinearLayout>


            <TextView
                android:id="@+id/labelBaseLevel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="" />

            <SeekBar
                android:id="@+id/sliderBaseLevel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:max="1500"
                android:progress="0" />


            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:text="Band Multipliers:"
                android:textSize="16sp"
                android:textStyle="bold|italic" />

            <TextView
                android:id="@+id/labelBand0"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="" />

            <SeekBar
                android:id="@+id/sliderBand0"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:max="200"
                android:progress="0" />

            <TextView
                android:id="@+id/labelBand1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="" />

            <SeekBar
                android:id="@+id/sliderBand1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:max="200"
                android:progress="0" />

            <TextView
                android:id="@+id/labelBand2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="" />

            <SeekBar
                android:id="@+id/sliderBand2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:max="200"
                android:progress="0" />

            <TextView
                android:id="@+id/labelBand3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="" />

            <SeekBar
                android:id="@+id/sliderBand3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:max="200"
                android:progress="0" />

            <TextView
                android:id="@+id/labelBand4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="" />

            <SeekBar
                android:id="@+id/sliderBand4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:max="200"
                android:progress="0" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>