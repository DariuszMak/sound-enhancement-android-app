<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0F"
    android:padding="20dp">

    <!-- Header -->
    <LinearLayout
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="EQUALIZER"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"/>

        <LinearLayout
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#1A1A2E"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp">

            <TextView
                android:id="@+id/statusDot"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="●"
                android:textColor="#444455"
                android:textSize="14sp"
                android:layout_marginEnd="6dp"/>

            <TextView
                android:id="@+id/statusLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OFF"
                android:textColor="#888888"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"/>
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PRESET · DYNAMIC BASS+"
        android:textColor="#333344"
        android:textSize="11sp"
        android:letterSpacing="0.12"
        android:layout_marginBottom="20dp"/>

    <!-- EQ Band sliders -->
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center_horizontal">

        <!-- Band 0 -->
        <LinearLayout android:orientation="vertical" android:gravity="center_horizontal"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1">
            <TextView android:id="@+id/label0"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0 dB" android:textColor="#00E5FF" android:textSize="9sp"
                android:layout_marginBottom="4dp"/>
            <SeekBar android:id="@+id/band0"
                android:layout_width="24dp" android:layout_height="160dp"
                android:rotation="270" android:max="100"
                android:progressTint="#00E5FF" android:thumbTint="#00E5FF"
                android:progressBackgroundTint="#1A2A2A"/>
            <TextView android:id="@+id/freq0"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="—" android:textColor="#555566" android:textSize="10sp"
                android:layout_marginTop="8dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Hz" android:textColor="#333344" android:textSize="9sp"/>
        </LinearLayout>

        <!-- Band 1 -->
        <LinearLayout android:orientation="vertical" android:gravity="center_horizontal"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1">
            <TextView android:id="@+id/label1"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0 dB" android:textColor="#00CCEE" android:textSize="9sp"
                android:layout_marginBottom="4dp"/>
            <SeekBar android:id="@+id/band1"
                android:layout_width="24dp" android:layout_height="160dp"
                android:rotation="270" android:max="100"
                android:progressTint="#00CCEE" android:thumbTint="#00CCEE"
                android:progressBackgroundTint="#1A2A2A"/>
            <TextView android:id="@+id/freq1"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="—" android:textColor="#555566" android:textSize="10sp"
                android:layout_marginTop="8dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Hz" android:textColor="#333344" android:textSize="9sp"/>
        </LinearLayout>

        <!-- Band 2 -->
        <LinearLayout android:orientation="vertical" android:gravity="center_horizontal"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1">
            <TextView android:id="@+id/label2"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0 dB" android:textColor="#00AADD" android:textSize="9sp"
                android:layout_marginBottom="4dp"/>
            <SeekBar android:id="@+id/band2"
                android:layout_width="24dp" android:layout_height="160dp"
                android:rotation="270" android:max="100"
                android:progressTint="#00AADD" android:thumbTint="#00AADD"
                android:progressBackgroundTint="#1A2A2A"/>
            <TextView android:id="@+id/freq2"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="—" android:textColor="#555566" android:textSize="10sp"
                android:layout_marginTop="8dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Hz" android:textColor="#333344" android:textSize="9sp"/>
        </LinearLayout>

        <!-- Band 3 -->
        <LinearLayout android:orientation="vertical" android:gravity="center_horizontal"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1">
            <TextView android:id="@+id/label3"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0 dB" android:textColor="#7B9FFF" android:textSize="9sp"
                android:layout_marginBottom="4dp"/>
            <SeekBar android:id="@+id/band3"
                android:layout_width="24dp" android:layout_height="160dp"
                android:rotation="270" android:max="100"
                android:progressTint="#7B9FFF" android:thumbTint="#7B9FFF"
                android:progressBackgroundTint="#1A2A2A"/>
            <TextView android:id="@+id/freq3"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="—" android:textColor="#555566" android:textSize="10sp"
                android:layout_marginTop="8dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Hz" android:textColor="#333344" android:textSize="9sp"/>
        </LinearLayout>

        <!-- Band 4 -->
        <LinearLayout android:orientation="vertical" android:gravity="center_horizontal"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1">
            <TextView android:id="@+id/label4"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0 dB" android:textColor="#9B8FFF" android:textSize="9sp"
                android:layout_marginBottom="4dp"/>
            <SeekBar android:id="@+id/band4"
                android:layout_width="24dp" android:layout_height="160dp"
                android:rotation="270" android:max="100"
                android:progressTint="#9B8FFF" android:thumbTint="#9B8FFF"
                android:progressBackgroundTint="#1A2A2A"/>
            <TextView android:id="@+id/freq4"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="—" android:textColor="#555566" android:textSize="10sp"
                android:layout_marginTop="8dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Hz" android:textColor="#333344" android:textSize="9sp"/>
        </LinearLayout>

        <!-- Band 5 -->
        <LinearLayout android:orientation="vertical" android:gravity="center_horizontal"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1">
            <TextView android:id="@+id/label5"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0 dB" android:textColor="#B57BFF" android:textSize="9sp"
                android:layout_marginBottom="4dp"/>
            <SeekBar android:id="@+id/band5"
                android:layout_width="24dp" android:layout_height="160dp"
                android:rotation="270" android:max="100"
                android:progressTint="#B57BFF" android:thumbTint="#B57BFF"
                android:progressBackgroundTint="#1A2A2A"/>
            <TextView android:id="@+id/freq5"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="—" android:textColor="#555566" android:textSize="10sp"
                android:layout_marginTop="8dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Hz" android:textColor="#333344" android:textSize="9sp"/>
        </LinearLayout>

        <!-- Band 6 -->
        <LinearLayout android:orientation="vertical" android:gravity="center_horizontal"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1">
            <TextView android:id="@+id/label6"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0 dB" android:textColor="#DD6FEE" android:textSize="9sp"
                android:layout_marginBottom="4dp"/>
            <SeekBar android:id="@+id/band6"
                android:layout_width="24dp" android:layout_height="160dp"
                android:rotation="270" android:max="100"
                android:progressTint="#DD6FEE" android:thumbTint="#DD6FEE"
                android:progressBackgroundTint="#1A2A2A"/>
            <TextView android:id="@+id/freq6"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="—" android:textColor="#555566" android:textSize="10sp"
                android:layout_marginTop="8dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Hz" android:textColor="#333344" android:textSize="9sp"/>
        </LinearLayout>

        <!-- Band 7 -->
        <LinearLayout android:orientation="vertical" android:gravity="center_horizontal"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1">
            <TextView android:id="@+id/label7"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0 dB" android:textColor="#FF4488" android:textSize="9sp"
                android:layout_marginBottom="4dp"/>
            <SeekBar android:id="@+id/band7"
                android:layout_width="24dp" android:layout_height="160dp"
                android:rotation="270" android:max="100"
                android:progressTint="#FF4488" android:thumbTint="#FF4488"
                android:progressBackgroundTint="#1A2A2A"/>
            <TextView android:id="@+id/freq7"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="—" android:textColor="#555566" android:textSize="10sp"
                android:layout_marginTop="8dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Hz" android:textColor="#333344" android:textSize="9sp"/>
        </LinearLayout>

    </LinearLayout>

    <!-- dB scale -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="min ─────────────────── max dB"
        android:textColor="#222233"
        android:textSize="10sp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="20dp"/>

    <!-- Buttons -->
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center">

        <Button
            android:id="@+id/btnStart"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="ENABLE"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:backgroundTint="#0D2A22"
            android:textColor="#00E5FF"
            android:stateListAnimator="@null"/>

        <Button
            android:id="@+id/btnStop"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="DISABLE"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:backgroundTint="#2A0A14"
            android:textColor="#FF4466"
            android:stateListAnimator="@null"/>

    </LinearLayout>

</LinearLayout>